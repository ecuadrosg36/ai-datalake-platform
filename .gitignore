# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.production

# Testing
.coverage
htmlcov/
.pytest_cache/

# OS files
.DS_Store
Thumbs.db

# Data files (too large for git)
data/raw/*
data/processed/*
data/sample/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
*.log
logs/
