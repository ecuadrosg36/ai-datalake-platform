# =============================================================================
# AI-Powered Data Lake Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Anthropic / Claude AI ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514
CLAUDE_ANALYSIS_MODEL=claude-opus-4-20250514

# --- AWS Configuration ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=ai-datalake-platform
AWS_GLUE_DATABASE=datalake_production

# --- Pipeline Configuration ---
PIPELINE_ENV=development
PIPELINE_LOG_LEVEL=INFO
PIPELINE_BATCH_SIZE=1000
PIPELINE_MAX_RETRIES=3

# --- MCP Server ---
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8080

# --- Data Sources (for demo/development) ---
DATA_DIR=./data
OUTPUT_DIR=./output
